# Local development env. Copy to .env.local (git-ignored) and edit.
# Lets `npm run dev` talk to your host's Docker daemon outside a container.

# Docker daemon connection. Accepts:
#   unix:///path/to/docker.sock  (or a bare /path/to/docker.sock)
#   tcp://host[:port]            (port defaults to 2375)
#   https://host:port
# macOS + Docker Desktop is typically ~/.docker/run/docker.sock:
# DOCKER_HOST=unix:///Users/you/.docker/run/docker.sock

# Path to the docker config.json used for registry credentials.
# DOCKER_CONFIG=/Users/you/.docker/config.json

# Poll cadence (300s, 5m, 0 disables).
# POLL_INTERVAL=300s

# Optional auth / webhook secrets (or use the *_FILE variants).
# ADMIN_PASSWORD=
# SESSION_SECRET=
# WEBHOOK_TOKEN=
